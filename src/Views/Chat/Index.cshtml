@{
    ViewData["Title"] = "Chat";
    var history = ViewBag.ConversationHistory as string ?? string.Empty;
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-chat-dots"></i> AI Chat Assistant</h1>
    <p class="text-muted">Ask our AI assistant anything about Zava Storefront.</p>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    <label for="conversationDisplay" class="form-label fw-bold">Conversation</label>
                    <textarea id="conversationDisplay" class="form-control mb-3" rows="14" readonly
                              style="font-family: inherit; background-color: #f8f9fa;">@history</textarea>

                    <form asp-controller="Chat" asp-action="Send" method="post">
                        <input type="hidden" name="conversationHistory" value="@history" />
                        <div class="input-group">
                            <input type="text" name="userMessage" class="form-control"
                                   placeholder="Type your message..." autofocus
                                   aria-label="Chat message" />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send"></i> Send
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
